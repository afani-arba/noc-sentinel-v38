#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║   NOC Sentinel v3.8 — One-Command Update Script                          ║
# ║                                                                           ║
# ║   INSTALL (sekali saja, setelah migrate.sh):                             ║
# ║     sudo cp /opt/noc-sentinel-v38/noc-update /usr/local/bin/noc-update   ║
# ║     sudo chmod +x /usr/local/bin/noc-update                              ║
# ║                                                                           ║
# ║   CARA PAKAI:  sudo noc-update                                           ║
# ╚══════════════════════════════════════════════════════════════════════════╝
set -e

APP_DIR="/opt/noc-sentinel-v38"
SERVICE="ARBAMonitoring"          # Nama service TETAP sama (sudah diarahkan oleh migrate.sh)
VENV="$APP_DIR/backend/venv"
[ -d "$APP_DIR/backend/.venv" ] && VENV="$APP_DIR/backend/.venv"

G='\033[0;32m'; Y='\033[1;33m'; R='\033[0;31m'; B='\033[1;34m'; N='\033[0m'; BOLD='\033[1m'
ok()   { echo -e "  ${G}✔ $*${N}"; }
warn() { echo -e "  ${Y}⚠ $*${N}"; }
err()  { echo -e "\n${R}${BOLD}✗ ERROR: $*${N}\n"; exit 1; }
step() { echo -e "\n${BOLD}${B}▶ $*${N}"; }

[[ $EUID -ne 0 ]] && err "Jalankan sebagai root: sudo noc-update38"
[[ ! -d "$APP_DIR/.git" ]] && err "Direktori $APP_DIR tidak ditemukan. Sudah di-install?"

echo -e "\n${BOLD}${B}╔════════════════════════════════════════════╗${N}"
echo -e "${BOLD}${B}║       NOC Sentinel v3.8 — Update           ║${N}"
echo -e "${BOLD}${B}╚════════════════════════════════════════════╝${N}"
echo -e "  Waktu : $(date '+%Y-%m-%d %H:%M:%S')"
echo -e "  Commit: $(git -C $APP_DIR rev-parse --short HEAD 2>/dev/null || echo '?')"
echo ""

# ══════════════════════════════════════════════════════════════════════════════
# STEP 1 — STOP SERVICE (bebaskan port 8080)
# ══════════════════════════════════════════════════════════════════════════════
step "[1/5] Stop Backend (port 8000)..."

systemctl stop "$SERVICE" 2>/dev/null || true

# Tunggu service inactive (max 20 detik)
i=0
while systemctl is-active --quiet "$SERVICE" 2>/dev/null && [[ $i -lt 20 ]]; do
    sleep 1; i=$((i+1))
done

# Bunuh paksa yang masih memegang port 8000
set +e
PIDS=$(lsof -ti:8000 2>/dev/null)
if [[ -n "$PIDS" ]]; then
    echo "  Membunuh proses di port 8000: $PIDS"
    kill -9 $PIDS 2>/dev/null
fi
fuser -k 8000/tcp 2>/dev/null
set -e

ok "Backend stopped — port 8000 bebas"

# ── 2. Git Pull ───────────────────────────────────────────────────────────────
step "[2/5] Git Pull dari GitHub..."
cd "$APP_DIR"
BEFORE=$(git rev-parse --short HEAD)
git pull origin main 2>/dev/null || git pull origin master 2>/dev/null || warn "Git pull gagal — melanjutkan dengan kode lokal"
AFTER=$(git rev-parse --short HEAD)

if [[ "$BEFORE" == "$AFTER" ]]; then
    warn "Tidak ada update baru (commit: $AFTER)"
else
    ok "Updated: $BEFORE → $AFTER ($(git log -1 --format='%s'))"
fi

# ── 3. Python deps ────────────────────────────────────────────────────────────
step "[3/5] Update Python packages..."
"$VENV/bin/pip" install --upgrade pip -q
"$VENV/bin/pip" install -r "$APP_DIR/backend/requirements.txt" -q
ok "Python packages OK"

# ── 4. Build Frontend ─────────────────────────────────────────────────────────
step "[4/5] Build Frontend..."
cd "$APP_DIR/frontend"
npm install --legacy-peer-deps --prefer-offline -q 2>/dev/null || npm install --legacy-peer-deps -q
npm run build
[[ -f "build/index.html" ]] && ok "Frontend build OK → build/" || err "Build frontend gagal"

# ── 5. Start Backend ──────────────────────────────────────────────────────────
step "[5/5] Start Backend..."

# Auto-fix SYSLOG_PORT jika masih 514 (privileged)
ENV_FILE="$APP_DIR/backend/.env"
if [[ -f "$ENV_FILE" ]] && grep -q "^SYSLOG_PORT=514$" "$ENV_FILE" 2>/dev/null; then
    sed -i 's/^SYSLOG_PORT=514$/SYSLOG_PORT=5140/' "$ENV_FILE"
    ok ".env: SYSLOG_PORT diperbaiki 514 → 5140"
fi

systemctl daemon-reload
systemctl start "$SERVICE"
sleep 5

if systemctl is-active --quiet "$SERVICE"; then
    ok "Backend '$SERVICE': RUNNING ✔"
else
    echo -e "${R}✗ Backend gagal start! Log:${N}"
    journalctl -u "$SERVICE" -n 30 --no-pager
    exit 1
fi

systemctl reload nginx 2>/dev/null && ok "Nginx di-reload" || true

sleep 2
if curl -sf http://localhost:8000/api/health 2>/dev/null | grep -q "ok"; then
    ok "API health check: OK ✔"
else
    warn "API belum respond — cek: journalctl -u $SERVICE -f"
fi

# ── Selesai ───────────────────────────────────────────────────────────────────
echo ""
echo -e "${G}${BOLD}╔════════════════════════════════════════════╗${N}"
echo -e "${G}${BOLD}║   ✅  UPDATE v3.8 SELESAI!                  ║${N}"
echo -e "${G}${BOLD}╚════════════════════════════════════════════╝${N}"
echo ""
echo -e "  Commit  : $(git -C $APP_DIR log -1 --format='%h — %s')"
echo -e "  Backend : $(systemctl is-active $SERVICE) (port 8000)"
echo -e "  Frontend: http://SERVER_IP:1755"
echo -e "  Waktu   : $(date '+%Y-%m-%d %H:%M:%S')"
echo ""
echo -e "  ${Y}➡ Hard refresh browser: Ctrl+Shift+R${N}"
echo ""

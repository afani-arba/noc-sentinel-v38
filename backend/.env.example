# NOC Sentinel v3 — Environment Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB connection string
MONGO_URI=mongodb://nocsentinel:GANTI_PASSWORD@localhost:27017/nocsentinel
MONGO_DB_NAME=nocsentinel

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GANTI_DENGAN_SECRET_KEY_ACAK_PANJANG

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL yang diizinkan. Pisahkan dengan koma jika lebih dari satu.
# Contoh: http://192.168.1.10  atau  https://noc.domainanda.com
CORS_ORIGINS=http://localhost:3000

# ─── Branding ─────────────────────────────────────────────────────────────────
NOC_SERVICE_NAME=ARBA Monitoring

# ─── Syslog Server ────────────────────────────────────────────────────────────
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# ─── InfluxDB (Opsional — time-series metrics) ────────────────────────────────
# Kosongkan jika tidak digunakan
INFLUXDB_URL=
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=

# ─── GenieACS (Opsional — TR-069 CPE Management) ─────────────────────────────
# Kosongkan jika tidak digunakan
GENIEACS_URL=
GENIEACS_USERNAME=
GENIEACS_PASSWORD=

# ─── WhatsApp Notification (Opsional) ────────────────────────────────────────
WA_API_URL=
WA_API_TOKEN=
